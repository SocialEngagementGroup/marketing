# Copy to .env.local and fill in. Never commit real values — *.local is gitignored.

# --- reCAPTCHA v3 ---------------------------------------------------------
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- n8n webhook ----------------------------------------------------------
# Production webhook URL for the contact form automation.
N8N_WEBHOOK_URL=

# Shared secret sent as the `X-Webhook-Secret` header on the call above.
# Must match the n8n "Header Auth" credential attached to the Webhook node.
# This is the same webhook the Website project posts to, so both projects must
# use the identical value.
# Generate with: openssl rand -hex 32
# Required — the API route fails closed (HTTP 500) if this is unset.
N8N_WEBHOOK_SECRET=
